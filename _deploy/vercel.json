{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/sub01/sub01_01",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/sub01/sub01_02_view",
      "destination": "/news_detail",
      "permanent": true
    },
    {
      "source": "/sub01/sub01_03_view",
      "destination": "/column_detail",
      "permanent": true
    },
    {
      "source": "/sub01/sub01_06",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/sub02/sub02_02",
      "destination": "/noblematching",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "noblehong.com"
        }
      ],
      "destination": "https://www.noblehong.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "noblehong.com"
        }
      ],
      "destination": "https://www.noblehong.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://noblehong-api.noblehong0.workers.dev/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://polarad.co.kr https://www.polarad.co.kr;"
        }
      ]
    },
    {
      "source": "/:all*(jpg|jpeg|png|webp|avif|gif|svg|ico|woff2|woff|ttf|mp4|webm|m4v)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(images|assets|fonts)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
